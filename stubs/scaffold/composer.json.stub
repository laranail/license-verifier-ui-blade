{
    "name": "$COMPOSER_NAME$",
    "description": "$PRESET_LABEL$ — generated license-verifier UI preset (extends $BASE_PACKAGE$).",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4 || ^8.5",
        "$BASE_PACKAGE$": "$BASE_CONSTRAINT$"
    },
    "autoload": {
        "psr-4": {
            "$PHP_NAMESPACE_JSON$\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "$PROVIDER_FQCN_JSON$"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
